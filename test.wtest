import loboFeroz.*
import personajes.*
import comidas.*
import historia.*

describe "Pruebas de la historia del Lobo" {

	test "El lobo empieza con peso 10 y no está saludable" {
		assert.equals(10, feroz.peso())
		assert.notThat(feroz.estaSaludable())
	}
	
	
	test "Si el cazador asusta al lobo, vuelve a su peso inicial" {
		historia.transcurrir()
		cazador.asustarA(feroz)
		assert.equals(10, feroz.peso())
	}

    	test "Luego dela historia completa con susto incluido, el peso vuelve a ser 10" {
		historia.transcurrir()
		assert.equals(10, feroz.peso()) 
	}


    	test "El lobo le roba canasta, pesa mas?" {
        feroz.robarA(caperucita)
		assert.equals(11.2, feroz.peso())
	}
    
    test "Verificar salud en final donde se come a todos" {
    historia.finalDondeGanaElLobo()
    
    assert.equals(29.1, feroz.peso())
    assert.that(feroz.estaSaludable())
    }


}
